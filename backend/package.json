{
  "name": "darbandb-backend",
  "version": "1.0.0",
  "description": "Backend pour B&B Hammamet",
  "main": "dist/app.js",
  "scripts": {
    "dev": "npx nodemon --exec npx tsx src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "migrate": "npx ts-node src/migrations/run.ts",
    "seed": "npx ts-node src/seeders/run.ts"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "sequelize": "^6.35.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.10.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.2"
  }
}
