{
  "name": "darbandb-backend",
  "version": "1.0.0",
  "description": "Backend pour B&B Hammamet",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npx nodemon --exec npx tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "npx ts-node src/migrations/run.ts",
    "seed": "npx ts-node src/seeders/run.ts"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "mysql2": "^3.22.5",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "resend": "^6.12.4",
    "sequelize": "^6.35.0"
  },
  "overrides": {
    "@whiskeysockets/baileys": {
      "whatsapp-rust-bridge": false
    }
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^8.0.1",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.2"
  }
}
